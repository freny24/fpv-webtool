# Copy this file to server/.env for local development.
# On Render, set these as Environment Variables in the dashboard instead
# (do not upload a .env file there).

PORT=3001

# Earth Engine credentials. Locally you can instead just drop your
# gee-service-account.json file in this folder and leave this blank.
# In production (Render), paste the FULL service account JSON here as a
# single-line string.
GEE_SERVICE_ACCOUNT_JSON=

# Shared secret required to access the admin review queue endpoints
# (GET /api/submissions, approve/reject). Pick a long random string.
ADMIN_KEY=

# Comma-separated list of frontend origins allowed to call this API.
# Leave blank in local dev to allow all origins.
# In production, set to your Vercel URL(s), e.g.:
# ALLOWED_ORIGINS=https://fpv-webtool.vercel.app,https://fpv-webtool-git-main-yourname.vercel.app
ALLOWED_ORIGINS=

# Where community submissions are stored (JSON file). Only relevant if you
# attach a persistent disk on Render — see DEPLOYMENT.md.
DATA_DIR=./data
